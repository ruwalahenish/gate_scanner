# ── NeonDB (free tier at neon.tech) ─────────────────────────────────
# Get from: neon.tech → Project → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/gate_platform?sslmode=require

# ── Redis ────────────────────────────────────────────────────────────
# Local Docker: redis://localhost:6379/0
# Upstash free tier: rediss://:<password>@<host>.upstash.io:6379
REDIS_URL=redis://localhost:6379/0

# ── CORS (comma-separated origins) ──────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000"]

# ── Telegram Alerts (optional, leave blank to disable) ───────────────
# Create bot: t.me/BotFather → /newbot
# Get chat ID: t.me/userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Gate Cache ───────────────────────────────────────────────────────
GATE_CACHE_DIR=../.gate_cache

# ── Scan Workers ─────────────────────────────────────────────────────
SCAN_EXECUTOR_WORKERS=4
