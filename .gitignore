# ============================================================================
# GATE Trading Intelligence Platform — .gitignore
# ============================================================================

# ----------------------------------------------------------------------------
# Python
# ----------------------------------------------------------------------------

# Bytecode / optimised files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/
sdist/
wheels/
pip-wheel-metadata/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# ----------------------------------------------------------------------------
# Virtual Environments
# ----------------------------------------------------------------------------
venv/
.venv/
env/
.env/
ENV/

# ----------------------------------------------------------------------------
# IDE / Editor
# ----------------------------------------------------------------------------

# VS Code
.vscode/

# JetBrains (PyCharm, IntelliJ)
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Neovim
*.swp
*.swo
*~

# Jupyter Notebook
.ipynb_checkpoints/

# ----------------------------------------------------------------------------
# OS Generated
# ----------------------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.Trash-*

# ----------------------------------------------------------------------------
# Project — Cache (auto-generated, fetched market data)
# ----------------------------------------------------------------------------
.gate_cache/

# ----------------------------------------------------------------------------
# Project — Output (auto-generated scan reports & charts)
# ----------------------------------------------------------------------------
gate_output/

# ----------------------------------------------------------------------------
# Environment Variables & Secrets
# ----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key

# ----------------------------------------------------------------------------
# Testing & Coverage
# ----------------------------------------------------------------------------
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.pytest_cache/
nosetests.xml
coverage.xml
*.cover

# ----------------------------------------------------------------------------
# Misc
# ----------------------------------------------------------------------------
*.log
*.bak
*.tmp
*.temp
.mypy_cache/
.ruff_cache/

# ----------------------------------------------------------------------------
# Next.js / Node.js (apps/web)
# ----------------------------------------------------------------------------
apps/web/node_modules/
apps/web/.next/
apps/web/out/
apps/web/.env.local
!apps/web/.env.local.example

# ----------------------------------------------------------------------------
# Redis / Celery
# ----------------------------------------------------------------------------
celerybeat-schedule
celerybeat.pid

# ----------------------------------------------------------------------------
# Docker
# ----------------------------------------------------------------------------
.docker/

# ----------------------------------------------------------------------------
# GSD Tool
# ----------------------------------------------------------------------------
.agents/
.planning/
.vercel
.env*


.playwright-mcp/